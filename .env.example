# ============================================================
# geo-editor — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --------------- App ports ---------------
ANGULAR_PORT=4200
REACT_PORT=3001

# --------------- MapLibre / Tiles --------
# No API key needed — uses public OSM tiles
VITE_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# --------------- localStorage key --------
VITE_STORAGE_KEY=poi_editor_state
NG_STORAGE_KEY=poi_editor_state

# --------------- Build mode --------------
NODE_ENV=development
