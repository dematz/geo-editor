  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular-devkit/core": "^21.2.9",
    "@nx/angular": "19.8.4",
    "@nx/eslint": "19.8.4",
    "@nx/js": "19.8.4",
    "@nx/react": "19.8.4",
    "@nx/vite": "19.8.4",
    "@types/geojson": "*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.0.0",
    "nx": "19.8.4",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
