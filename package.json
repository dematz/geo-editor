{
  "name": "geo-editor",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "serve:angular": "nx serve angular-app",
    "serve:react": "nx serve react-app",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "lint:all": "nx run-many --target=lint --all",
